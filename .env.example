# Copy to .env and adjust. Used by agent_pipeline.py / pipeline module (python-dotenv) and can mirror docker-compose.
POSTGRES_USER=poc
POSTGRES_PASSWORD=pocsecret
POSTGRES_DB=pocdb
POSTGRES_PORT=5432

# Full URL for the Python entrypoints
DATABASE_URL=postgresql://poc:pocsecret@127.0.0.1:5432/pocdb

# Ollama (host machine talks to published port 11434)
# After `docker compose up -d ollama`, pull the model once (match OLLAMA_MODEL): `docker compose exec ollama ollama pull qwen2.5:14b-instruct`
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b-instruct
OLLAMA_PORT=11434

# Optional: cap data sent to the model
# MAX_RESULT_ROWS=200
# MAX_RESULT_CHARS=12000

# --- agent_pipeline.py (Ollama tools; also shared settings for the pipeline module) ---
# Use a model that supports tool calling, e.g.:
#   docker compose exec ollama ollama pull qwen2.5:14b-instruct
# OLLAMA_MODEL=qwen2.5:14b-instruct
# AGENT_MAX_TOOL_ROUNDS=8
# AGENT_WEB_SEARCH=1
# Comma-separated URL prefixes; default is localhost/127.0.0.1 only.
# FETCH_URL_ALLOWLIST_PREFIXES=https://127.0.0.1,https://www.example.com
# send_email tool: prints draft to stderr only; no SMTP (see llm_agent_tools.py)
